# ─────────────────────────────────────────────────────────────
# Real Domínio — Variáveis de Ambiente
# Copie este conteúdo para as variáveis do Railway
# ─────────────────────────────────────────────────────────────

# Banco de dados — cole a URL do Supabase aqui
# Encontre em: Supabase → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres"

# Segredo da sessão — coloque qualquer texto longo e aleatório
# Exemplo: junta palavras aleatórias com números
NEXTAUTH_SECRET="real-dominio-chave-secreta-2025-troque-isso"

# URL do seu sistema no Railway (Railway fornece automaticamente)
# Exemplo: https://real-dominio-production.up.railway.app
NEXTAUTH_URL="https://SEU-PROJETO.up.railway.app"

# Ambiente
NODE_ENV="production"
