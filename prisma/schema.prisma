enum PerfilGlobal {
  DIRETORIA
  COORDENADOR
  LIDER
  OPERADOR
  CONSULTA
}

model Usuario {
  id                String       @id @default(uuid())
  nome              String
  email             String       @unique
  senhaHash         String
  perfilGlobal      PerfilGlobal @default(OPERADOR)
  ativo             Boolean      @default(true)
  podeVerComercial  Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  setores           UsuarioSetor[]
  auditoria         Auditoria[]
  notificacoes      Notificacao[]
  obrigacoesResp    ObrigacaoInstancia[]
  tarefasResp       Tarefa[]
  eventosResp       Evento[]

  // FK reversas dos respons鈹溍璿eis em Empresa
  empresasFiscal    Empresa[]    @relation("RespFiscal")
  empresasContabil  Empresa[]    @relation("RespContabil")
  empresasDp        Empresa[]    @relation("RespDp")
  empresasSociet    Empresa[]    @relation("RespSocietario")
  empresasCarteira  Empresa[]    @relation("RespCarteira")

  @@map("usuarios")
}

model Setor {
  id          String   @id @default(uuid())
  nome        String   @unique
  descricao   String?
  ativo       Boolean  @default(true)
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios          UsuarioSetor[]
  obrigacaoTemplates ObrigacaoTemplate[]
  tarefas           Tarefa[]
  eventos           Evento[]
  tiposEvento       TipoEvento[]

  @@map("setores")
}

model UsuarioSetor {
  id         String   @id @default(uuid())
  usuarioId  String
  setorId    String
  papel      String   @default("membro") // membro | lider
  createdAt  DateTime @default(now())

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  setor      Setor    @relation(fields: [setorId], references: [id])

  @@unique([usuarioId, setorId])
  @@map("usuario_setores")
}

