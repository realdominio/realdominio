enum StatusEvento {
  NAO_INICIADO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_ORGAO
  AGUARDANDO_SETOR
  CONCLUIDO
  CANCELADO
}

model TipoEvento {
  id       String  @id @default(uuid())
  nome     String
  setorId  String?
  ativo    Boolean @default(true)

  setor    Setor?  @relation(fields: [setorId], references: [id])
  eventos  Evento[]

  @@map("tipos_evento")
}

model Evento {
  id                String       @id @default(uuid())
  empresaId         String
  tipoEventoId      String?
  respGeralId       String?
  setorAtualId      String?
  respAtualId       String?
  dataAbertura      DateTime     @default(now())
  prazo             DateTime?
  status            StatusEvento @default(NAO_INICIADO)
  observacoes       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  empresa     Empresa     @relation(fields: [empresaId],    references: [id])
  tipoEvento  TipoEvento? @relation(fields: [tipoEventoId], references: [id])
  setorAtual  Setor?      @relation(fields: [setorAtualId], references: [id])
  respAtual   Usuario?    @relation(fields: [respAtualId],  references: [id])

  historico   EventoHistorico[]
  tarefas     Tarefa[]

  @@map("eventos")
}

model EventoHistorico {
  id             String   @id @default(uuid())
  eventoId       String
  usuarioId      String?
  dataHora       DateTime @default(now())
  descricao      String
  statusAnterior String?
  statusNovo     String?

  evento   Evento   @relation(fields: [eventoId], references: [id])

  @@map("evento_historico")
}

enum StatusTarefa {
  NAO_INICIADO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_ORGAO
  AGUARDANDO_SETOR
  CONCLUIDO
  CANCELADO
}

model Tarefa {
  id             String       @id @default(uuid())
  empresaId      String
  eventoId       String?
  setorId        String?
  responsavelId  String?
  titulo         String
  descricao      String?
  dataInicio     DateTime?
  prazo          DateTime?
  dataConclusao  DateTime?
  status         StatusTarefa @default(NAO_INICIADO)
  motivoAtraso   String?
  observacoes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  empresa      Empresa   @relation(fields: [empresaId],    references: [id])
  evento       Evento?   @relation(fields: [eventoId],     references: [id])
  setor        Setor?    @relation(fields: [setorId],      references: [id])
  responsavel  Usuario?  @relation(fields: [responsavelId],references: [id])

  @@map("tarefas")
}

