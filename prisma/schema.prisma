model Fiscal {
  id                   String           @id @default(uuid())
  empresaId            String           @unique
  regimeTributario     RegimeTributario?
  inicioRegime         DateTime?
  ultimaRevisao        DateTime?
  proximaRevisao       DateTime?
  inscricaoEstadual    String?
  inscricaoMunicipal   String?
  acessoEstado         String?
  acessoPrefeitura     String?
  parcelamentoAtivo    Boolean          @default(false)
  qtdParcelamentos     Int              @default(0)
  orgaoParcelamento    String?
  situacaoParcelamento String?
  possuiDebitos        Boolean          @default(false)
  prefEnvioGuia        String?          // WHATSAPP | EMAIL | AMBOS
  diaPrefEnvio         Int?
  updatedAt            DateTime         @updatedAt

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("fiscal")
}

model Contabil {
  id                  String    @id @default(uuid())
  empresaId           String    @unique
  ultimoFechamento    DateTime?
  competenciaFech     String?
  qtdContasBancarias  Int       @default(0)
  contaPrincipal      String?
  pessoaExtratos      String?
  formaExtratos       String?
  obsExtratos         String?
  possuiEmprestimo    Boolean   @default(false)
  possuiFinanciamento Boolean   @default(false)
  ultimoResultado     String?   // LUCRO | PREJUIZO | EQUILIBRIO
  competenciaResult   String?
  confiabilidade      String?   // TOTAL | PARCIAL | NAO_SABEMOS | NAO
  updatedAt           DateTime  @updatedAt

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("contabil")
}

model Dp {
  id                  String   @id @default(uuid())
  empresaId           String   @unique
  possuiFuncionarios  Boolean  @default(false)
  qtdFuncionarios     Int      @default(0)
  possuiProlabore     Boolean  @default(false)
  qtdSociosfolha      Int      @default(0)
  possuiInssPatronal  Boolean  @default(false)
  possuiPisFolha      Boolean  @default(false)
  rat                 Decimal? @db.Decimal(5, 2)
  fap                 Decimal? @db.Decimal(5, 4)
  terceiros           Boolean  @default(false)
  updatedAt           DateTime @updatedAt

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("dp")
}

model Societario {
  id                    String    @id @default(uuid())
  empresaId             String    @unique
  contratoAtualizado    Boolean   @default(false)
  ultimaAlteracaoContr  DateTime?
  certificadoDigital    Boolean   @default(false)
  tipoCertificado       String?   // A1 | A3
  situacaoCertificado   String?   // ATIVO | VENCIDO | A_VENCER
  vencimentoCertificado DateTime?
  procuracaoRF          Boolean   @default(false)
  procuracaoEstado      Boolean   @default(false)
  procuracaoMunicipio   Boolean   @default(false)
  acessoRF              String?
  acessoEstado          String?
  acessoMunicipio       String?
  licencas              String?
  alvaras               String?
  updatedAt             DateTime  @updatedAt

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("societario")
}

model Relacionamento {
  id                 String    @id @default(uuid())
  empresaId          String    @unique
  ultimoContato      DateTime?
  ultimaReuniao      DateTime?
  ultimaVisita       DateTime?
  formaPrefContato   String?   // WHATSAPP | EMAIL | TELEFONE | PRESENCIAL
  tempoResposta      String?   // RAPIDO | MEDIO | LENTO
  perfilCliente      String?   // ORGANIZADO | DESORGANIZADO | TECNICO | etc
  updatedAt          DateTime  @updatedAt

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("relacionamento")
}

model Comercial {
  id                String    @id @default(uuid())
  empresaId         String    @unique
  origem            String?   // GOOGLE | INSTAGRAM | INDICACAO | etc
  quemIndicou       String?
  motivoContratacao String?
  honorarios        Decimal?  @db.Decimal(10, 2)
  contrato          String?
  dataEntrada       DateTime?
  motivoSaida       String?
  descricaoSaida    String?
  updatedAt         DateTime  @updatedAt

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("comercial")
}

model Irpf {
  id                   String   @id @default(uuid())
  pessoaId             String
  ano                  Int
  declaracaoEntregue   Boolean  @default(false)
  imoveis              String?
  participacoes        String?
  investimentos        String?
  patrimonio           String?
  contasBancarias      String?
  observacoes          String?
  updatedAt            DateTime @updatedAt

  pessoa  Pessoa @relation(fields: [pessoaId], references: [id])

  @@unique([pessoaId, ano])
  @@map("irpf")
}

