// 脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟脭枚脟

enum StatusEmpresa {
  CADASTRO_INCOMPLETO
  IMPLANTACAO
  ATIVA
  EM_ATENCAO
  INATIVA
  ENCERRADA
  EX_CLIENTE
}

enum RegimeTributario {
  MEI
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  CARNE_LEAO
  ISENTO
  OUTRO
}

model Empresa {
  id              String        @id @default(uuid())
  codigoInterno   String        @unique
  cnpj            String        @unique
  razaoSocial     String
  nomeFantasia    String?
  municipio       String?
  bairro          String?
  estado          String?
  dataAbertura    DateTime?
  status          StatusEmpresa @default(CADASTRO_INCOMPLETO)
  dataEntrada     DateTime?
  obsCritica      String?
  obsAtual        String?
  ativo           Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  respFiscalId    String?
  respContabilId  String?
  respDpId        String?
  respSocietId    String?
  respCarteiraId  String?

  respFiscal      Usuario?      @relation("RespFiscal",    fields: [respFiscalId],   references: [id])
  respContabil    Usuario?      @relation("RespContabil",  fields: [respContabilId], references: [id])
  respDp          Usuario?      @relation("RespDp",        fields: [respDpId],       references: [id])
  respSocietario  Usuario?      @relation("RespSocietario",fields: [respSocietId],   references: [id])
  respCarteira    Usuario?      @relation("RespCarteira",  fields: [respCarteiraId], references: [id])

  // M鈹溾攤dulos setoriais (1:1)
  fiscal          Fiscal?
  contabil        Contabil?
  dp              Dp?
  societario      Societario?
  relacionamento  Relacionamento?
  comercial       Comercial?

  // Rela鈹溌衡敎脕es
  socios          EmpresaPessoa[]
  eventos         Evento[]
  tarefas         Tarefa[]
  obrigacoes      ObrigacaoEmpresa[]
  documentos      Documento[]
  obsHistorico    ObsHistorico[]

  @@map("empresas")
}

model Pessoa {
  id            String    @id @default(uuid())
  nome          String
  cpf           String    @unique
  dataNascimento DateTime?
  estadoCivil   String?
  telefone      String?
  email         String?
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  conjugeId     String?
  conjuge       Pessoa?   @relation("Conjuge", fields: [conjugeId], references: [id])
  conjugeDe     Pessoa[]  @relation("Conjuge")

  dependentes   PessoaDependente[] @relation("Responsavel")
  dependenteDe  PessoaDependente[] @relation("Dependente")

  empresas      EmpresaPessoa[]
  irpf          Irpf[]
  documentos    Documento[]

  @@map("pessoas")
}

model EmpresaPessoa {
  id                    String   @id @default(uuid())
  empresaId             String
  pessoaId              String
  percentualParticipacao Decimal? @db.Decimal(5, 2)
  eAdministrador        Boolean  @default(false)
  dataInicio            DateTime?
  dataFim               DateTime?
  createdAt             DateTime @default(now())

  empresa  Empresa @relation(fields: [empresaId], references: [id])
  pessoa   Pessoa  @relation(fields: [pessoaId], references: [id])

  @@unique([empresaId, pessoaId])
  @@map("empresa_pessoas")
}

model PessoaDependente {
  id             String   @id @default(uuid())
  responsavelId  String
  dependenteId   String
  parentesco     String?

  responsavel  Pessoa @relation("Responsavel", fields: [responsavelId], references: [id])
  dependente   Pessoa @relation("Dependente",  fields: [dependenteId],  references: [id])

  @@unique([responsavelId, dependenteId])
  @@map("pessoa_dependentes")
}

