enum StatusObrigacao {
  NAO_INICIADO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  RECEBIDO_PARCIALMENTE
  RECEBIDO
  ENVIADO
  CONCLUIDO
  NAO_SE_APLICA
  EM_ATRASO
}

model ObrigacaoTemplate {
  id          String   @id @default(uuid())
  setorId     String
  nome        String
  descricao   String?
  ativo       Boolean  @default(true)
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())

  setor       Setor    @relation(fields: [setorId], references: [id])
  empresas    ObrigacaoEmpresa[]

  @@map("obrigacao_templates")
}

model ObrigacaoEmpresa {
  id           String   @id @default(uuid())
  empresaId    String
  templateId   String
  setorId      String?
  ativa        Boolean  @default(true)
  createdAt    DateTime @default(now())

  empresa   Empresa           @relation(fields: [empresaId], references: [id])
  template  ObrigacaoTemplate @relation(fields: [templateId], references: [id])

  instancias  ObrigacaoInstancia[]

  @@unique([empresaId, templateId])
  @@map("obrigacao_empresas")
}

model ObrigacaoInstancia {
  id                String          @id @default(uuid())
  obrigacaoEmpresaId String
  responsavelId     String?
  competencia       String          // formato: "YYYY-MM"
  status            StatusObrigacao @default(NAO_INICIADO)
  dataConclusao     DateTime?
  observacao        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  obrigacaoEmpresa  ObrigacaoEmpresa @relation(fields: [obrigacaoEmpresaId], references: [id])
  responsavel       Usuario?         @relation(fields: [responsavelId],      references: [id])

  @@unique([obrigacaoEmpresaId, competencia])
  @@map("obrigacao_instancias")
}

